# Strat Edge Project Portal - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL (for production)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# =============================================================================
# AZURE STORAGE CONFIGURATION
# =============================================================================

# Azure Blob Storage Connection String
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Azure Container Name for file storage
AZURE_CONTAINER_NAME=strat-edge-files

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Secret key for cookie signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production

# =============================================================================
# SEED USER PASSWORDS (Change these in production!)
# =============================================================================

# If not set, secure random passwords will be generated and printed to console
SEED_ADMIN_PASSWORD=YourSecureAdminPassword123!
SEED_PM_PASSWORD=YourSecurePMPassword123!
SEED_EXEC_PASSWORD=YourSecureExecPassword123!
SEED_TEAM_PASSWORD=YourSecureTeamPassword123!

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Streamlit server port (default: 8501)
STREAMLT_PORT=8501

# Application environment (development, staging, production)
APP_ENV=development

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
# 1. Never commit .env file to version control
# 2. Use strong, unique passwords for each user
# 3. Rotate COOKIE_SECRET regularly
# 4. Use environment-specific values for different deployments
# 5. Store production secrets in a secure vault (Azure Key Vault, AWS Secrets Manager, etc.)
